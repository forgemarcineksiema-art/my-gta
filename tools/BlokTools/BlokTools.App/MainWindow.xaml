<Window x:Class="BlokTools.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BlokTools" Width="1500" Height="860" MinWidth="1300" MinHeight="760"
        Background="#F2F0EA">
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="BorderBrush" Value="#C8C3B8"/>
            <Setter Property="Background" Value="#FCFBF7"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="BorderBrush" Value="#C8C3B8"/>
            <Setter Property="Background" Value="#FCFBF7"/>
            <Setter Property="AlternatingRowBackground" Value="#F4F1EA"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#272727" Padding="18,14">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="Save Mission"
                        Command="{Binding SaveCommand}"
                        Padding="14,6"
                        Margin="16,0,0,0"/>
                <Button DockPanel.Dock="Right"
                        Content="Add Cutscene Line"
                        Command="{Binding AddCutsceneCommand}"
                        Padding="12,6"
                        Margin="10,0,0,0"/>
                <Button DockPanel.Dock="Right"
                        Content="Add NPC Reaction"
                        Command="{Binding AddNpcReactionCommand}"
                        Padding="12,6"
                        Margin="10,0,0,0"/>
                <Button DockPanel.Dock="Right"
                        Content="Bind Outcome"
                        Command="{Binding BindOutcomeCommand}"
                        Padding="12,6"
                        Margin="10,0,0,0"/>
                <Button DockPanel.Dock="Right"
                        Content="Add Dialogue"
                        Command="{Binding AddDialogueCommand}"
                        Padding="12,6"
                        Margin="10,0,0,0"/>
                <Button DockPanel.Dock="Right"
                        Content="Add Step"
                        Command="{Binding AddStepCommand}"
                        Padding="12,6"
                        Margin="10,0,0,0"/>
                <Button DockPanel.Dock="Right"
                        Content="Add Shop Item"
                        Command="{Binding AddShopItemCommand}"
                        Padding="12,6"
                        Margin="10,0,0,0"/>
                <Button DockPanel.Dock="Right"
                        Content="Add Shop"
                        Command="{Binding AddShopCommand}"
                        Padding="12,6"
                        Margin="10,0,0,0"/>
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding Header}"
                           Foreground="#F5F1E8"
                           FontSize="20"
                           FontWeight="SemiBold"/>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding Status}"
                           Foreground="#D8D0C2"
                           FontSize="13"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.0*"/>
                <ColumnDefinition Width="1.0*"/>
                <ColumnDefinition Width="1.0*"/>
                <ColumnDefinition Width="1.0*"/>
                <ColumnDefinition Width="1.0*"/>
                <ColumnDefinition Width="1.0*"/>
                <ColumnDefinition Width="1.0*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Mission Steps" Grid.Column="0">
                <DataGrid ItemsSource="{Binding MissionSteps}"
                          SelectedItem="{Binding SelectedMissionStep, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Phase" Binding="{Binding Phase}" IsReadOnly="True" Width="110"/>
                        <DataGridTextColumn Header="Objective" Binding="{Binding Objective, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridTextColumn Header="Trigger" Binding="{Binding Trigger, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox Header="Dialogue" Grid.Column="1">
                <DataGrid ItemsSource="{Binding DialogueLines}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Phase" Binding="{Binding Phase, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="95"/>
                        <DataGridTextColumn Header="Speaker" Binding="{Binding Speaker, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                        <DataGridTextColumn Header="Line Key" Binding="{Binding LineKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                        <DataGridTextColumn Header="Text" Binding="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridTextColumn Header="Seconds" Binding="{Binding DurationSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox Header="NPC Reactions" Grid.Column="2">
                <DataGrid ItemsSource="{Binding NpcReactions}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Phase" Binding="{Binding Phase, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                        <DataGridTextColumn Header="Speaker" Binding="{Binding Speaker, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                        <DataGridTextColumn Header="Line Key" Binding="{Binding LineKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
                        <DataGridTextColumn Header="Text" Binding="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridTextColumn Header="Sec" Binding="{Binding DurationSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox Header="Cutscenes" Grid.Column="3">
                <DataGrid ItemsSource="{Binding CutsceneLines}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Cutscene" Binding="{Binding Cutscene, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                        <DataGridTextColumn Header="Phase" Binding="{Binding Phase, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                        <DataGridTextColumn Header="Speaker" Binding="{Binding Speaker, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                        <DataGridTextColumn Header="Line Key" Binding="{Binding LineKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
                        <DataGridTextColumn Header="Text" Binding="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridTextColumn Header="Sec" Binding="{Binding DurationSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox Header="Object Outcomes" Grid.Column="4" Margin="0">
                <ListBox ItemsSource="{Binding ObjectOutcomeHooks}"
                         SelectedItem="{Binding SelectedObjectOutcomeHook, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}" Margin="4,5"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <GroupBox Header="Shops" Grid.Column="5">
                <DataGrid ItemsSource="{Binding Shops}"
                          SelectedItem="{Binding SelectedShop, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id" Binding="{Binding Id}" IsReadOnly="True" Width="80"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                        <DataGridTextColumn Header="Kind" Binding="{Binding Kind, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                        <DataGridTextColumn Header="Location" Binding="{Binding LocationTag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                        <DataGridTextColumn Header="Open" Binding="{Binding IsOpen, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="55"/>
                        <DataGridTextColumn Header="Tags" Binding="{Binding Tags, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox Header="Shop Items" Grid.Column="6">
                <DataGrid ItemsSource="{Binding ShopItems}"
                          SelectedItem="{Binding SelectedShopItem, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id" Binding="{Binding Id}" IsReadOnly="True" Width="80"/>
                        <DataGridTextColumn Header="Shop" Binding="{Binding ShopId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                        <DataGridTextColumn Header="Category" Binding="{Binding Category, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                        <DataGridTextColumn Header="Price" Binding="{Binding Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                        <DataGridTextColumn Header="Currency" Binding="{Binding Currency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

        <Border Grid.Row="2" Background="#E2DED4" BorderBrush="#C8C3B8" BorderThickness="0,1,0,0" Padding="16,10">
            <ItemsControl ItemsSource="{Binding IssueRows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Text}" Foreground="#5E3B34" Margin="0,1"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </Grid>
</Window>
